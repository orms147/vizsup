# Copy to .env and fill in ONLY the providers you want to use.
# The free local default (edge-tts + yt-dlp + ffmpeg) needs no keys.

# --- Translation providers (pick any) ---
OPENROUTER_API_KEY=          # one key, any model (https://openrouter.ai/keys)
OPENROUTER_MODEL=            # e.g. deepseek/deepseek-chat-v3 — pick via Settings → Fetch models
DEEPSEEK_API_KEY=            # deepseek-v4-flash / deepseek-v4-pro  (https://platform.deepseek.com)
ANTHROPIC_API_KEY=           # Claude Opus/Sonnet 4.x refine pass
ZHIPU_API_KEY=               # GLM-5.2 (https://open.bigmodel.cn)
GEMINI_API_KEY=              # Google Gemini
DASHSCOPE_API_KEY=           # Qwen3 (Alibaba DashScope)
DEEPL_API_KEY=               # DeepL (gist baseline)

# --- TTS providers (edge-tts default needs no key) ---
FPT_API_KEY=                 # FPT.AI Vietnamese TTS
AZURE_SPEECH_KEY=            # Azure Neural vi-VN
AZURE_SPEECH_REGION=
GOOGLE_APPLICATION_CREDENTIALS=   # path to Google Cloud TTS service-account json
ELEVENLABS_API_KEY=          # optional, for future voice cloning

# --- Download ---
# Path to a Netscape-format cookies.txt exported from your logged-in browser.
# Douyin in particular needs fresh cookies and still breaks sometimes.
YTDLP_COOKIES_FILE=
# Or use a browser profile directly (chrome/edge/firefox); leave blank to disable.
YTDLP_COOKIES_FROM_BROWSER=

# --- Paths / defaults ---
FFMPEG_PATH=                 # optional: path to ffmpeg.exe or its bin dir (else found on PATH)
VIZSUP_STORAGE_DIR=./storage
VIZSUP_DEFAULT_TRANSLATOR=deepseek
VIZSUP_DEFAULT_TTS=edge
VIZSUP_DEFAULT_ASR=whisperx_funasr
